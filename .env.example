# ============================================
# Hotel & Resort Management System
# Environment Configuration
# ============================================

# Application
APP_NAME="Hotel & Resort Management System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/hotel-management
APP_TIMEZONE=UTC

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hotel_management
DB_USERNAME=root
DB_PASSWORD=

# Upload
UPLOAD_PATH=uploads

# Session
SESSION_NAME=HOTEL_SESSION
SESSION_LIFETIME=3600

# Security
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Currency
CURRENCY_CODE=USD
CURRENCY_SYMBOL=$
CURRENCY_POSITION=left

# Email
MAIL_FROM_NAME="Hotel & Resort Management System"
MAIL_FROM_EMAIL=noreply@hotel-management.com
MAIL_ENABLED=false

# Pagination
ITEMS_PER_PAGE=20

# Logging
LOG_ENABLED=true
LOG_LEVEL=INFO
